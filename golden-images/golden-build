#!/usr/bin/env bash
# ============================================================================
# golden-build — Docker SSH Golden Image Builder
# ============================================================================
# Single entry point for building, testing, and managing SSH-enabled Docker
# golden images across all major Linux distributions.
#
# Usage:
#   golden-build [command] [options]
#
# Commands:
#   run      Build all images (default)
#   setup    Check dependencies, create config
#   status   Show current/last build status
#   report   Generate report from last build
#   clean    Remove build artifacts
#
# Run options:
#   -p, --parallel N     Parallel workers (default: 6)
#   -m, --matrix FILE    Matrix file (default: images.matrix)
#   -c, --config FILE    Config file (default: golden-build.conf)
#   --tui / --no-tui     Enable/disable TUI dashboard (auto-detect)
#   --json               Generate JSON report
#   --push               Push images after build
#   --no-verify          Skip SSH verification
#   --clean              Clean before building
#   -h, --help           Show this help
# ============================================================================
set -euo pipefail

export GB_VERSION="2.0.0"
export GB_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export GB_SCRIPT="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"

# ── Load libraries ──────────────────────────────────────────────────────────
for _lib in "$GB_ROOT"/lib/*.sh; do
  [[ -f "$_lib" ]] || continue
  # shellcheck disable=SC1090
  source "$_lib"
done
unset _lib

# ── Internal mode dispatch (used by background workers) ─────────────────────
case "${1:-}" in
  __worker)  shift; gb_worker_run "$@"; exit $? ;;
  __tui)     shift; gb_tui_loop  "$@"; exit $? ;;
esac

# ── CLI argument parsing ────────────────────────────────────────────────────
GB_COMMAND="${1:-run}"
case "$GB_COMMAND" in
  run|setup|status|report|clean) shift 2>/dev/null || true ;;
  -h|--help) GB_COMMAND="help" ;;
  -*) ;; # Options without a command → default to "run"
  *)  GB_COMMAND="run" ;;
esac

# Parse remaining flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--parallel)     GB_PARALLELISM="$2"; shift 2 ;;
    -m|--matrix)       GB_MATRIX_FILE="$2"; shift 2 ;;
    -c|--config)       GB_CONFIG_FILE="$2"; shift 2 ;;
    --tui)             GB_USE_TUI="yes"; shift ;;
    --no-tui)          GB_USE_TUI="no"; shift ;;
    --json)            GB_JSON_REPORT="1"; shift ;;
    --push)            GB_PUSH_IMAGES="1"; shift ;;
    --no-verify)       GB_VERIFY_IMAGES="0"; shift ;;
    --clean)           GB_CLEAN_FIRST="1"; shift ;;
    -h|--help)         GB_COMMAND="help"; shift ;;
    *)                 gb_log_error "Unknown option: $1"; exit 1 ;;
  esac
done

# ── Command dispatch ────────────────────────────────────────────────────────

cmd_help() {
  sed -n '2,/^# =====/{ /^#/s/^# \?//p }' "$GB_SCRIPT"
}

cmd_setup() {
  gb_log_header "Golden Build Setup"

  # Check required tools
  local missing=()
  for cmd in docker curl; do
    command -v "$cmd" >/dev/null 2>&1 || missing+=("$cmd")
  done

  # Recommended tools
  local recommended=()
  for cmd in jq sshpass nc; do
    command -v "$cmd" >/dev/null 2>&1 || recommended+=("$cmd")
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    gb_log_error "Missing required tools: ${missing[*]}"
    gb_log_info "Install them and re-run setup."
    return 1
  fi
  gb_log_ok "Required tools: docker, curl"

  if [[ ${#recommended[@]} -gt 0 ]]; then
    gb_log_warn "Recommended tools not found: ${recommended[*]}"
    gb_log_info "  jq      — JSON parsing for registry API"
    gb_log_info "  sshpass — SSH password-based verification"
    gb_log_info "  nc      — Port readiness checking"
  else
    gb_log_ok "Recommended tools: jq, sshpass, nc"
  fi

  # Create default config if not present
  local conf="${GB_CONFIG_FILE:-$GB_ROOT/golden-build.conf}"
  if [[ ! -f "$conf" ]]; then
    cp "$GB_ROOT/golden-build.conf.default" "$conf" 2>/dev/null || true
    gb_log_ok "Created config: $conf"
  else
    gb_log_info "Config exists: $conf"
  fi

  # Docker connectivity
  if docker info >/dev/null 2>&1; then
    gb_log_ok "Docker daemon: running"
  else
    gb_log_error "Docker daemon: not running or not accessible"
    return 1
  fi

  # Registry auth check
  if [[ -n "${DOCKER_USERNAME:-}" ]]; then
    gb_log_ok "Docker Hub auth: $DOCKER_USERNAME (200 pulls/6h)"
  else
    gb_log_warn "Docker Hub auth: anonymous (100 pulls/6h)"
    gb_log_info "  Set DOCKER_USERNAME + DOCKER_PASSWORD for higher limits"
  fi

  gb_log_header "Setup Complete"
  gb_log_info "Run: golden-build run"
}

cmd_clean() {
  gb_config_load
  gb_log_header "Cleaning build artifacts"
  if [[ -d "$GB_WORK_DIR" ]]; then
    rm -rf "$GB_WORK_DIR"
    gb_log_ok "Removed: $GB_WORK_DIR"
  else
    gb_log_info "Nothing to clean."
  fi
}

cmd_status() {
  gb_config_load
  if [[ ! -d "$GB_WORK_DIR/.results" ]]; then
    gb_log_info "No build results found. Run: golden-build run"
    return 0
  fi
  gb_report_text "$GB_WORK_DIR"
}

cmd_report() {
  gb_config_load
  if [[ ! -d "$GB_WORK_DIR/.results" ]]; then
    gb_log_info "No build results found. Run: golden-build run"
    return 0
  fi
  gb_report_text "$GB_WORK_DIR"
  gb_report_json "$GB_WORK_DIR"
  gb_log_ok "JSON report: $GB_WORK_DIR/report.json"
}

cmd_run() {
  gb_config_load
  gb_registry_login

  # Clean if requested
  if [[ "${GB_CLEAN_FIRST:-0}" == "1" ]]; then
    rm -rf "$GB_WORK_DIR"
  fi

  # Init directories
  gb_queue_init

  # Parse matrix → build plan → queue
  gb_log_header "Build Plan"
  local total
  total="$(gb_queue_populate "$GB_MATRIX_FILE")"
  gb_log_info "Queue: $total image(s), parallelism=$GB_PARALLELISM"
  gb_log_info "Logs:  $GB_LOG_DIR/"

  if [[ "$total" -eq 0 ]]; then
    gb_log_warn "Nothing to build."
    return 0
  fi

  # Save state for workers
  gb_config_save_runtime

  # Launch workers + dashboard
  gb_log_header "Building Images"
  date +%s > "$GB_WORK_DIR/.wall_start"
  echo "$total" > "$GB_WORK_DIR/.total_jobs"

  if [[ "${GB_USE_TUI:-auto}" != "no" ]] && [[ -t 1 ]]; then
    # ── TUI mode: background workers + foreground dashboard ──
    local pids=()
    for ((i = 1; i <= GB_PARALLELISM; i++)); do
      bash "$GB_SCRIPT" __worker "$i" "$GB_WORK_DIR" &
      pids+=($!)
    done

    # Run TUI in foreground (blocks until done or user quits)
    bash "$GB_SCRIPT" __tui "$GB_WORK_DIR" || true

    # Ensure all workers finish
    for pid in "${pids[@]}"; do
      wait "$pid" 2>/dev/null || true
    done
  else
    # ── Headless mode: xargs parallel ──
    gb_worker_run_headless "$GB_WORK_DIR"
  fi

  # Reports
  gb_log_header "Build Complete"
  gb_report_text "$GB_WORK_DIR"
  gb_report_errors "$GB_WORK_DIR"

  if [[ "${GB_JSON_REPORT:-0}" == "1" ]]; then
    gb_report_json "$GB_WORK_DIR"
    gb_log_ok "JSON report: $GB_WORK_DIR/report.json"
  fi

  # Exit code
  local fail_count
  fail_count=$(find "$GB_WORK_DIR/.results" -name '*.fail' ! -name '*SCHEMA1*' 2>/dev/null | wc -l)
  [[ "$fail_count" -gt 0 ]] && return 1
  return 0
}

# ── Execute ─────────────────────────────────────────────────────────────────
case "$GB_COMMAND" in
  help)   cmd_help ;;
  setup)  cmd_setup ;;
  clean)  cmd_clean ;;
  status) cmd_status ;;
  report) cmd_report ;;
  run)    cmd_run ;;
  *)      gb_log_error "Unknown command: $GB_COMMAND"; cmd_help; exit 1 ;;
esac
